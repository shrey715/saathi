# Used by `docker compose up`. Copy to .env and fill in.
# Individual service defaults live in server/.env.example and client/.env.local.example —
# this file only covers what docker-compose.yml itself reads.

# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

ALLOWED_ORIGINS=http://localhost:3000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

LLM_PROVIDER=mistralai
LLM_MODEL=mistral-small-latest
MISTRAL_API_KEY=

ENABLE_GUARDRAIL=false
