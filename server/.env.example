# Copy to .env and fill in. Never commit the real .env file.

# SQLite by default — a single file, no separate DB service to run or deploy.
# Semantic search (/api/search, chat grounding) still works on SQLite via a
# brute-force cosine scan; it just won't use a real vector index.
DATABASE_URL=sqlite:///./saathi.db

# For production / `docker compose up`, point this at Postgres with pgvector
# instead (the psycopg driver is already a dependency):
#   DATABASE_URL=postgresql+psycopg://saathi:saathi@localhost:5432/saathi

# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=240

ALLOWED_ORIGINS=http://localhost:3000,https://saathi-eight.vercel.app
PORT=8000

# --- LLM provider (swap freely, no code changes needed) -----------------
# LLM_PROVIDER: mistralai | groq | openai | google_genai | ollama
LLM_PROVIDER=mistralai
LLM_MODEL=mistral-small-latest
MISTRAL_API_KEY=

# --- Embeddings provider, for RAG / semantic search ----------------------
# Defaults to LLM_PROVIDER's embedding model if unset. Dimension is only
# needed if EMBEDDING_PROVIDER isn't one of the providers with a known
# default dimension (see llm/embeddings.py).
# EMBEDDING_PROVIDER=mistralai
# EMBEDDING_MODEL=mistral-embed
# EMBEDDING_DIM=1024

# Alternative free-tier providers — set LLM_PROVIDER accordingly and fill
# in the matching key:
# GROQ_API_KEY=
# GOOGLE_API_KEY=

# Self-hosted / a friend's machine running an OpenAI-compatible server
# (Ollama, vLLM, llama.cpp, LM Studio, text-generation-webui, ...):
#   LLM_PROVIDER=openai
#   LLM_MODEL=<model name the server exposes>
#   LLM_BASE_URL=http://<host>:<port>/v1
#   OPENAI_API_KEY=not-needed   # most local servers ignore this but the SDK requires a value

# Set to "true" to run a safety review pass over every assistant reply
# before it's returned (costs one extra LLM call per message).
ENABLE_GUARDRAIL=false

# On an empty database, seeds a login-ready demo account (username "demo",
# password "demo1234") plus sample journals, mood history, and community
# posts — so a fresh `docker compose up` has something to explore
# immediately instead of a blank app. No-op once the database has any
# users. Turn this off for a real deployment, since it creates an account
# with a known password.
SEED_DEMO_DATA=true
